{
  "name": "@vigolium/vigolium-audit",
  "version": "0.1.15-alpha",
  "private": true,
  "description": "vigolium-audit — autonomous agent that performs thorough security audits on your codebase, part of Vigolium",
  "keywords": [
    "vigolium",
    "security-audit",
    "codex",
    "claude",
    "claude-code",
    "agent-sdk",
    "anthropic",
    "openai"
  ],
  "homepage": "https://www.vigolium.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vigolium/vigolium-audit.git"
  },
  "bugs": {
    "url": "https://github.com/vigolium/vigolium-audit/issues"
  },
  "author": "Vigolium",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "vigolium-audit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "build:all": "bun run build.ts --all",
    "transform": "bun run scripts/transform-content.ts",
    "sync-scanner-skill": "bun run scripts/sync-scanner-skill.ts",
    "upgrade": "bun run scripts/upgrade.ts",
    "release": "bun run scripts/release.ts",
    "release:dry": "VIGOLIUM_AUDIT_RELEASE_DRY_RUN=1 bun run scripts/release.ts",
    "npm-publish": "bun run scripts/npm-publish.ts",
    "npm-publish:dry": "VIGOLIUM_AUDIT_NPM_DRY_RUN=1 bun run scripts/npm-publish.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "lint:eslint": "eslint .",
    "preflight": "bun run typecheck && bun run lint && bun run lint:eslint && bun test && VIGOLIUM_AUDIT_BUILD_NO_INSTALL=1 bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.199",
    "@openai/codex-sdk": "^0.142.5",
    "cac": "^6.7.14",
    "chalk": "^5.6.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
